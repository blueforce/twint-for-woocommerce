msgid "Einstellungen"
msgstr "Einstellungen"

msgid "TWINT for WooCommerce benötigt ein aktives WooCommerce."
msgstr "TWINT for WooCommerce benötigt ein aktives WooCommerce."

msgid "TWINT"
msgstr "TWINT"

msgid "TWINT als Offline-Zahlung – ohne API, ohne Vertrag mit TWINT. Ablauf «Kunde sendet» (deine TWINT-Nummer/QR wird angezeigt) oder «Ich fordere an» (Kunde gibt seine TWINT-Nummer an). Der Zahlungseingang wird von Hand bestätigt."
msgstr "TWINT als Offline-Zahlung – ohne API, ohne Vertrag mit TWINT. Ablauf „Kunde sendet“ (deine TWINT-Nummer/QR wird angezeigt) oder „Ich fordere an“ (Kunde gibt seine TWINT-Nummer an). Der Zahlungseingang wird von Hand bestätigt."

msgid "Aktivieren"
msgstr "Aktivieren"

msgid "TWINT als Bezahlmethode aktivieren"
msgstr "TWINT als Bezahlmethode aktivieren"

msgid "Titel"
msgstr "Titel"

msgid "Im Checkout angezeigter Name."
msgstr "Im Checkout angezeigter Name."

msgid "Beschreibung"
msgstr "Beschreibung"

msgid "Kurztext unter dem Methodennamen im Checkout."
msgstr "Kurztext unter dem Methodennamen im Checkout."

msgid "Bezahle einfach und sicher mit TWINT."
msgstr "Bezahle einfach und sicher mit TWINT."

msgid "Ablauf"
msgstr "Ablauf"

msgid "«Kunde sendet»: deine TWINT-Nummer wird angezeigt. «Ich fordere an»: Kunde gibt seine TWINT-Nummer an, du forderst den Betrag."
msgstr "„Kunde sendet“: deine TWINT-Nummer wird angezeigt. „Ich fordere an“: Kunde gibt seine TWINT-Nummer an, du forderst den Betrag."

msgid "Kunde sendet an meine TWINT-Nummer"
msgstr "Kunde sendet an meine TWINT-Nummer"

msgid "Ich fordere den Betrag an (Kunde gibt Nummer an)"
msgstr "Ich fordere den Betrag an (Kunde gibt Nummer an)"

msgid "Deine TWINT-Handynummer"
msgstr "Deine TWINT-Handynummer"

msgid "Nur bei «Kunde sendet»: Nummer, an die der Betrag gesendet wird (z. B. +41 79 123 45 67)."
msgstr "Nur bei „Kunde sendet“: Nummer, an die der Betrag gesendet wird (z. B. +41 79 123 45 67)."

msgid "Name des Kontoinhabers"
msgstr "Name des Kontoinhabers"

msgid "Optional. Wird dem Kunden zur Kontrolle angezeigt (z. B. Firmen- oder Personenname)."
msgstr "Optional. Wird dem Kunden zur Kontrolle angezeigt (z. B. Firmen- oder Personenname)."

msgid "TWINT-QR-Bild"
msgstr "TWINT-QR-Bild"

msgid "Optional, nur bei «Kunde sendet». Lade in der TWINT-App unter «Geld empfangen» deinen QR-Code, speichere ihn als Bild und wähle ihn hier aus der Mediathek. Der Kunde kann ihn dann direkt scannen."
msgstr "Optional, nur bei „Kunde sendet“. Lade in der TWINT-App unter „Geld empfangen“ deinen QR-Code, speichere ihn als Bild und wähle ihn hier aus der Mediathek. Der Kunde kann ihn dann direkt scannen."

msgid "Bild auswählen"
msgstr "Bild auswählen"

msgid "Entfernen"
msgstr "Entfernen"

msgid "TWINT-QR-Bild wählen"
msgstr "TWINT-QR-Bild wählen"

msgid "Dieses Bild verwenden"
msgstr "Dieses Bild verwenden"

msgid "Zusätzliche Hinweise"
msgstr "Zusätzliche Hinweise"

msgid "Erscheint auf der Danke-Seite und in der Bestell-E-Mail."
msgstr "Erscheint auf der Danke-Seite und in der Bestell-E-Mail."

msgid "Wir bearbeiten deine Bestellung, sobald die Zahlung eingegangen ist."
msgstr "Wir bearbeiten deine Bestellung, sobald die Zahlung eingegangen ist."

msgid "TWINT-Handynummer"
msgstr "TWINT-Handynummer"

msgid "Pflichtfeld"
msgstr "Pflichtfeld"

msgid "An diese Nummer senden wir dir eine TWINT-Zahlungsanforderung."
msgstr "An diese Nummer senden wir dir eine TWINT-Zahlungsanforderung."

msgid "Sende den Betrag via TWINT an %s – die genauen Angaben erhältst du nach der Bestellung."
msgstr "Sende den Betrag via TWINT an %s – die genauen Angaben erhältst du nach der Bestellung."

msgid "Bitte gib eine gültige TWINT-Handynummer an, damit wir die Zahlung anfordern können."
msgstr "Bitte gib eine gültige TWINT-Handynummer an, damit wir die Zahlung anfordern können."

msgid "TWINT: Zahlungsanforderung an %s senden."
msgstr "TWINT: Zahlungsanforderung an %s senden."

msgid "(keine Nummer angegeben)"
msgstr "(keine Nummer angegeben)"

msgid "TWINT: Warten auf Zahlungseingang (Kunde sendet)."
msgstr "TWINT: Warten auf Zahlungseingang (Kunde sendet)."

msgid "Wir senden dir in Kürze eine <strong>TWINT-Zahlungsanforderung</strong>%s. Bitte bestätige die Zahlung in deiner TWINT-App."
msgstr "Wir senden dir in Kürze eine <strong>TWINT-Zahlungsanforderung</strong>%s. Bitte bestätige die Zahlung in deiner TWINT-App."

msgid "an %s"
msgstr "an %s"

msgid "Bitte sende %1$s via <strong>TWINT</strong>%2$s."
msgstr "Bitte sende %1$s via <strong>TWINT</strong>%2$s."

msgid "Kontoinhaber: %s"
msgstr "Kontoinhaber: %s"

msgid "Verwende deine Bestellnummer %s als Mitteilung."
msgstr "Verwende deine Bestellnummer %s als Mitteilung."

msgid "TWINT-QR-Code"
msgstr "TWINT-QR-Code"

msgid "TWINT-Handynummer (Kunde):"
msgstr "TWINT-Handynummer (Kunde):"

msgid "keine"
msgstr "keine"

msgid "Vorgehen:"
msgstr "Vorgehen:"

msgid "1. In der TWINT-App den Betrag (%1$s) an diese Nummer anfordern – Bestellnummer %2$s als Mitteilung."
msgstr "1. In der TWINT-App den Betrag (%1$s) an diese Nummer anfordern – Bestellnummer %2$s als Mitteilung."

msgid "2. Nach Zahlungseingang: Status auf «In Bearbeitung» setzen."
msgstr "2. Nach Zahlungseingang: Status auf „In Bearbeitung“ setzen."

msgid "3. Nach Versand: «Abgeschlossen»."
msgstr "3. Nach Versand: „Abgeschlossen“."

msgid "TWINT-Ablauf:"
msgstr "TWINT-Ablauf:"

msgid "Kunde sendet den Betrag selbst."
msgstr "Kunde sendet den Betrag selbst."

msgid "1. Prüfe in der TWINT-App den Eingang von %1$s mit Mitteilung %2$s."
msgstr "1. Prüfe in der TWINT-App den Eingang von %1$s mit Mitteilung %2$s."

msgid "Sende den Betrag via TWINT an %s – Details erhältst du nach der Bestellung."
msgstr "Sende den Betrag via TWINT an %s – Details erhältst du nach der Bestellung."

msgid "Bitte gib deine TWINT-Handynummer an, damit wir die Zahlung anfordern können."
msgstr "Bitte gib deine TWINT-Handynummer an, damit wir die Zahlung anfordern können."

msgid "Wir senden dir eine TWINT-Zahlungsanforderung an diese Nummer."
msgstr "Wir senden dir eine TWINT-Zahlungsanforderung an diese Nummer."

msgid "Kopieren"
msgstr "Kopieren"

msgid "Kopiert!"
msgstr "Kopiert!"

msgid "Bestellnummer kopieren"
msgstr "Bestellnummer kopieren"

msgid "Zahlung erhalten – Bestellung freigeben"
msgstr "Zahlung erhalten – Bestellung freigeben"

msgid "TWINT-Zahlung von Hand als erhalten bestätigt."
msgstr "TWINT-Zahlung von Hand als erhalten bestätigt."

msgid "Du hast keine Berechtigung, diese Bestellung zu bearbeiten."
msgstr "Du hast keine Berechtigung, diese Bestellung zu bearbeiten."
